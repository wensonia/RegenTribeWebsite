---
import Layout from '../../layouts/Layout.astro';
import { marked } from 'marked';
import fs from 'node:fs';
import path from 'node:path';

const base = import.meta.env.BASE_URL.replace(/\/$/, '');

const filePath = path.join(process.cwd(), 'src/content/community-alchemy-playbook.md');
const raw = fs.readFileSync(filePath, 'utf-8');
const content = marked(raw);

const steps = [
  { num: 1, name: 'Hone Your Vision', phase: 'Phase 1', desc: 'Establish purpose, mission, and values' },
  { num: 2, name: 'Recruit Your Ideal Members', phase: 'Phase 1', desc: 'Build a core team with aligned values' },
  { num: 3, name: 'Align with Group Agreements & Governance', phase: 'Phase 1', desc: 'Develop written community agreements' },
  { num: 4, name: 'Plan Business Models & Infrastructure', phase: 'Phase 2', desc: 'Design physical spaces and income streams' },
  { num: 5, name: 'Acquire the Best Land', phase: 'Phase 2', desc: 'Identify and secure appropriate property' },
  { num: 6, name: 'Identify Your Funding Needs', phase: 'Phase 2–3', desc: 'Assess financial requirements and sources' },
  { num: 7, name: 'Strategize Marketing', phase: 'Phase 2–3', desc: 'Attract members and support business models' },
  { num: 8, name: 'Master Plan Sustainable Systems', phase: 'Phase 3', desc: 'Design water, energy, and food systems' },
  { num: 9, name: 'Construct Physical Infrastructure', phase: 'Phase 3', desc: 'Build structures reflecting community values' },
  { num: 10, name: 'Activate Community Culture', phase: 'Phase 3–4', desc: 'Establish rituals, activities, and practices' },
  { num: 11, name: 'Manage & Review Holistic Ecosystems', phase: 'Phase 4', desc: 'Maintain systems and continuously adapt' },
];

const phaseColors: Record<string, string> = {
  'Phase 1': '#3d5a3e',
  'Phase 2': '#8b6b4a',
  'Phase 2–3': '#a07050',
  'Phase 3': '#6b9ab8',
  'Phase 3–4': '#5a8aa8',
  'Phase 4': '#9b7eb8',
};
---

<Layout title="Community Alchemy — The Journey Map" description="11 sequential domains guiding you from vision to living community.">

  <div style="background: linear-gradient(135deg, #4a3020, #8b6b4a); color: #f5f0e8; padding: 3rem 1.5rem 2.5rem;">
    <div style="max-width: 900px; margin: 0 auto;">
      <a href={`${base}/`} style="color: #e0c8b0; font-size: 0.875rem; text-decoration: none;">← Home</a>
      <div style="display: flex; align-items: center; gap: 1rem; margin-top: 1rem;">
        <span style="font-size: 3rem;">🧭</span>
        <div>
          <p style="font-size: 0.8rem; letter-spacing: 0.12em; text-transform: uppercase; color: #d4b890; margin-bottom: 0.25rem;">Framework 2 of 4</p>
          <h1 style="font-size: 2.25rem; font-weight: bold; margin: 0;">Community Alchemy</h1>
          <p style="color: #e8d4b8; margin-top: 0.5rem;">A Regenerative Neighborhood Co-Creation Playbook</p>
        </div>
      </div>
    </div>
  </div>

  <div style="background-color: #f5ede0; border-bottom: 1px solid #e0c8a8; padding: 1rem 1.5rem;">
    <div style="max-width: 900px; margin: 0 auto;">
      <p style="font-size: 0.95rem; color: #5a3d20; font-style: italic;">"You can't build community alone."</p>
    </div>
  </div>

  <!-- 11 Steps -->
  <section style="max-width: 900px; margin: 3rem auto; padding: 0 1.5rem;">
    <h2 style="font-size: 1.5rem; font-weight: bold; color: #8b6b4a; margin-bottom: 1.5rem;">The 11 Domains</h2>

    <div style="display: flex; flex-direction: column; gap: 0; position: relative;">
      <!-- Connecting line -->
      <div style="position: absolute; left: 1.125rem; top: 1.5rem; bottom: 1.5rem; width: 2px; background: linear-gradient(to bottom, #3d5a3e, #9b7eb8); z-index: 0;"></div>

      {steps.map((step, i) => {
        const color = phaseColors[step.phase] || '#8b6b4a';
        return (
          <div style="display: flex; gap: 1.5rem; margin-bottom: 0.875rem; position: relative; z-index: 1;">
            <div style={`background: ${color}; color: white; width: 2.25rem; height: 2.25rem; border-radius: 50%; display: flex; align-items: center; justify-content: center; font-weight: bold; font-size: 0.875rem; flex-shrink: 0; box-shadow: 0 2px 6px rgba(0,0,0,0.2);`}>
              {step.num}
            </div>
            <div style="background: white; flex: 1; border-radius: 0.75rem; padding: 0.875rem 1.25rem; box-shadow: 0 2px 8px rgba(0,0,0,0.07);">
              <div style="display: flex; justify-content: space-between; align-items: baseline; flex-wrap: wrap; gap: 0.25rem;">
                <span style={`font-weight: bold; color: ${color};`}>{step.name}</span>
                <span style={`font-size: 0.75rem; background: ${color}22; color: ${color}; padding: 0.125rem 0.625rem; border-radius: 9999px; font-weight: 600;`}>{step.phase}</span>
              </div>
              <p style="font-size: 0.875rem; color: #78716c; margin-top: 0.25rem;">{step.desc}</p>
            </div>
          </div>
        );
      })}
    </div>
  </section>

  <!-- Phase legend -->
  <section style="background: #e8dcc8; padding: 2rem 1.5rem;">
    <div style="max-width: 900px; margin: 0 auto;">
      <h3 style="font-size: 1rem; font-weight: bold; color: #44403c; margin-bottom: 1rem;">Phase Legend</h3>
      <div style="display: flex; flex-wrap: wrap; gap: 0.75rem;">
        {Object.entries(phaseColors).map(([phase, color]) => (
          <div style="display: flex; align-items: center; gap: 0.5rem;">
            <div style={`width: 1rem; height: 1rem; border-radius: 50%; background: ${color};`}></div>
            <span style="font-size: 0.875rem; color: #44403c;">{phase}</span>
          </div>
        ))}
      </div>
    </div>
  </section>

  <!-- Full content -->
  <section style="max-width: 900px; margin: 3rem auto 4rem; padding: 0 1.5rem;">
    <h2 style="font-size: 1.5rem; font-weight: bold; color: #8b6b4a; margin-bottom: 1.5rem;">Full Playbook</h2>
    <div style="background: white; border-radius: 1rem; padding: 2.5rem; box-shadow: 0 2px 12px rgba(0,0,0,0.07);">
      <div class="md-content" set:html={content} />
    </div>
  </section>

</Layout>

<style>
.md-content h1 { font-size: 1.75rem; font-weight: bold; color: #8b6b4a; margin-top: 2rem; margin-bottom: 1rem; }
.md-content h2 { font-size: 1.35rem; font-weight: bold; color: #8b6b4a; margin-top: 2rem; margin-bottom: 0.75rem; padding-bottom: 0.375rem; border-bottom: 2px solid #e0c8a8; }
.md-content h3 { font-size: 1.1rem; font-weight: 600; color: #a07050; margin-top: 1.5rem; margin-bottom: 0.5rem; }
.md-content p { margin-bottom: 1rem; line-height: 1.75; }
.md-content ul, .md-content ol { padding-left: 1.5rem; margin-bottom: 1rem; }
.md-content li { margin-bottom: 0.375rem; line-height: 1.6; }
.md-content ul { list-style-type: disc; }
.md-content ol { list-style-type: decimal; }
.md-content blockquote { border-left: 4px solid #c8a070; padding: 0.75rem 1.25rem; margin: 1.5rem 0; background: #faf0e0; font-style: italic; color: #6b4820; border-radius: 0 0.375rem 0.375rem 0; }
.md-content table { width: 100%; border-collapse: collapse; margin-bottom: 1.5rem; font-size: 0.875rem; display: block; overflow-x: auto; }
.md-content th { background-color: #8b6b4a; color: #f5f0e8; padding: 0.625rem 1rem; text-align: left; }
.md-content td { border: 1px solid #e0c8a8; padding: 0.625rem 1rem; }
.md-content tr:nth-child(even) td { background-color: #faf8f4; }
.md-content strong { font-weight: bold; }
.md-content hr { border: none; border-top: 1px solid #e0c8a8; margin: 2rem 0; }
.md-content code { background: #f5ede0; padding: 0.125rem 0.375rem; border-radius: 0.25rem; font-size: 0.85rem; font-family: monospace; }
</style>
