---
import Layout from '../../layouts/Layout.astro';
import { marked } from 'marked';
import fs from 'node:fs';
import path from 'node:path';

const base = import.meta.env.BASE_URL.replace(/\/$/, '');

const filePath = path.join(process.cwd(), 'src/content/RCOS.md');
const raw = fs.readFileSync(filePath, 'utf-8');
const content = marked(raw);

const layers = [
  { num: 0, name: 'Identity & Scope', question: 'Why do we exist and what do we govern?', phase: 'Phase 1' },
  { num: 1, name: 'Membership', question: 'How do people join, participate, and exit?', phase: 'Phase 1' },
  { num: 2, name: 'Governance', question: 'Who decides what and through which processes?', phase: 'Phase 1' },
  { num: 3, name: 'Economy & Resources', question: 'How do we manage resource circulation?', phase: 'Phase 2–3' },
  { num: 4, name: 'Conflict, Repair & Accountability', question: 'How do we address disputes and restore trust?', phase: 'Phase 1 onward' },
  { num: 5, name: 'Operations & Coordination', question: 'How do we organize daily work sustainably?', phase: 'Phase 3–4' },
  { num: 6, name: 'Evolution', question: 'How do we learn and improve over time?', phase: 'Phase 4' },
];
---

<Layout title="RCOS — The Governance OS" description="Regenerative Community Operating System: 7 modular governance layers for intentional communities.">

  <div style="background: linear-gradient(135deg, #1a3a5c, #2d6a8a); color: #f5f0e8; padding: 3rem 1.5rem 2.5rem;">
    <div style="max-width: 900px; margin: 0 auto;">
      <a href={`${base}/`} style="color: #b8d4e8; font-size: 0.875rem; text-decoration: none;">← Home</a>
      <div style="display: flex; align-items: center; gap: 1rem; margin-top: 1rem;">
        <span style="font-size: 3rem;">⚙️</span>
        <div>
          <p style="font-size: 0.8rem; letter-spacing: 0.12em; text-transform: uppercase; color: #8fc8e0; margin-bottom: 0.25rem;">Framework 3 of 4</p>
          <h1 style="font-size: 2.25rem; font-weight: bold; margin: 0;">RCOS — The Governance OS</h1>
          <p style="color: #c8e0f0; margin-top: 0.5rem;">Regenerative Community Operating System</p>
        </div>
      </div>
    </div>
  </div>

  <div style="background-color: #e8f0f7; border-bottom: 1px solid #c8d8e8; padding: 1rem 1.5rem;">
    <div style="max-width: 900px; margin: 0 auto; display: flex; flex-wrap: wrap; gap: 0.75rem; align-items: center;">
      <span style="font-size: 0.875rem; color: #2d6a8a; font-style: italic; font-weight: 600;">Key principle:</span>
      <span style="font-size: 0.875rem; color: #44403c;">"Explicit beats implicit."</span>
    </div>
  </div>

  <!-- 7 Layers -->
  <section style="max-width: 900px; margin: 3rem auto; padding: 0 1.5rem;">
    <h2 style="font-size: 1.5rem; font-weight: bold; color: #2d6a8a; margin-bottom: 1.5rem;">The 7 Layers</h2>
    <p style="color: #44403c; margin-bottom: 2rem; line-height: 1.6;">Each layer is independent and modular. Start with Layer 0 before people join, then build upward.</p>
    <div style="display: flex; flex-direction: column; gap: 0.75rem;">
      {layers.map(layer => (
        <div style="background: white; border-radius: 0.75rem; padding: 1.25rem 1.5rem; box-shadow: 0 2px 8px rgba(0,0,0,0.07); border-left: 5px solid #6b9ab8; display: flex; gap: 1.25rem; align-items: flex-start;">
          <div style="background: #2d6a8a; color: white; min-width: 2.5rem; height: 2.5rem; border-radius: 0.5rem; display: flex; align-items: center; justify-content: center; font-weight: bold; font-size: 0.9rem; flex-shrink: 0;">
            L{layer.num}
          </div>
          <div style="flex: 1;">
            <div style="display: flex; justify-content: space-between; align-items: baseline; flex-wrap: wrap; gap: 0.25rem;">
              <span style="font-weight: bold; color: #1c1917;">{layer.name}</span>
              <span style="font-size: 0.75rem; color: #6b9ab8; background: #e8f0f7; padding: 0.125rem 0.625rem; border-radius: 9999px;">{layer.phase}</span>
            </div>
            <p style="font-size: 0.875rem; color: #78716c; margin-top: 0.25rem; font-style: italic;">{layer.question}</p>
          </div>
        </div>
      ))}
    </div>
  </section>

  <!-- Full content -->
  <section style="max-width: 900px; margin: 3rem auto 4rem; padding: 0 1.5rem;">
    <h2 style="font-size: 1.5rem; font-weight: bold; color: #2d6a8a; margin-bottom: 1.5rem;">Full Framework Documentation</h2>
    <div style="background: white; border-radius: 1rem; padding: 2.5rem; box-shadow: 0 2px 12px rgba(0,0,0,0.07);">
      <div class="md-content" set:html={content} />
    </div>
  </section>

</Layout>

<style>
.md-content h1 { font-size: 1.75rem; font-weight: bold; color: #2d6a8a; margin-top: 2rem; margin-bottom: 1rem; }
.md-content h2 { font-size: 1.35rem; font-weight: bold; color: #2d6a8a; margin-top: 2rem; margin-bottom: 0.75rem; padding-bottom: 0.375rem; border-bottom: 2px solid #c8d8e8; }
.md-content h3 { font-size: 1.1rem; font-weight: 600; color: #3a7a9a; margin-top: 1.5rem; margin-bottom: 0.5rem; }
.md-content p { margin-bottom: 1rem; line-height: 1.75; }
.md-content ul, .md-content ol { padding-left: 1.5rem; margin-bottom: 1rem; }
.md-content li { margin-bottom: 0.375rem; line-height: 1.6; }
.md-content ul { list-style-type: disc; }
.md-content ol { list-style-type: decimal; }
.md-content blockquote { border-left: 4px solid #6b9ab8; padding: 0.75rem 1.25rem; margin: 1.5rem 0; background: #e8f0f7; font-style: italic; color: #2d6a8a; border-radius: 0 0.375rem 0.375rem 0; }
.md-content table { width: 100%; border-collapse: collapse; margin-bottom: 1.5rem; font-size: 0.875rem; display: block; overflow-x: auto; }
.md-content th { background-color: #2d6a8a; color: #f5f0e8; padding: 0.625rem 1rem; text-align: left; }
.md-content td { border: 1px solid #c8d8e8; padding: 0.625rem 1rem; }
.md-content tr:nth-child(even) td { background-color: #f5f9fc; }
.md-content strong { font-weight: bold; }
.md-content hr { border: none; border-top: 1px solid #c8d8e8; margin: 2rem 0; }
.md-content code { background: #e8f0f7; padding: 0.125rem 0.375rem; border-radius: 0.25rem; font-size: 0.85rem; font-family: monospace; }
</style>
