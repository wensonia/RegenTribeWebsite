---
import Layout from '../../layouts/Layout.astro';
import { marked } from 'marked';
import fs from 'node:fs';
import path from 'node:path';

const base = import.meta.env.BASE_URL.replace(/\/$/, '');

const filePath = path.join(process.cwd(), 'src/content/EXECUTIVE-SUMMARY.md');
const raw = fs.readFileSync(filePath, 'utf-8');
const content = marked(raw);
---

<Layout title="RNF — The Architecture" description="The Regenerative Neighborhood Framework: 5 pillars, 5 phases, and a gate system for building regenerative communities.">

  <!-- Header -->
  <div style="background: linear-gradient(135deg, #2e4430, #3d5a3e); color: #f5f0e8; padding: 3rem 1.5rem 2.5rem;">
    <div style="max-width: 900px; margin: 0 auto;">
      <a href={`${base}/`} style="color: #b8d4a8; font-size: 0.875rem; text-decoration: none;">← Home</a>
      <div style="display: flex; align-items: center; gap: 1rem; margin-top: 1rem;">
        <span style="font-size: 3rem;">🏗️</span>
        <div>
          <p style="font-size: 0.8rem; letter-spacing: 0.12em; text-transform: uppercase; color: #8fba7a; margin-bottom: 0.25rem;">Framework 1 of 4</p>
          <h1 style="font-size: 2.25rem; font-weight: bold; margin: 0;">RNF — The Architecture</h1>
          <p style="color: #d4e8c8; margin-top: 0.5rem;">Regenerative Neighborhood Framework</p>
        </div>
      </div>
    </div>
  </div>

  <!-- Quick summary pills -->
  <div style="background-color: #f0f7ec; border-bottom: 1px solid #d4e8c8; padding: 1rem 1.5rem;">
    <div style="max-width: 900px; margin: 0 auto; display: flex; flex-wrap: wrap; gap: 0.75rem;">
      {['5 Pillars', '5 Phases', 'Gate System', 'Ecology as OS', 'Open Source'].map(tag => (
        <span style="background: #3d5a3e; color: #d4e8c8; padding: 0.25rem 0.75rem; border-radius: 9999px; font-size: 0.8rem;">{tag}</span>
      ))}
    </div>
  </div>

  <!-- 5 Pillars visual -->
  <section style="max-width: 900px; margin: 3rem auto; padding: 0 1.5rem;">
    <h2 style="font-size: 1.5rem; font-weight: bold; color: #3d5a3e; margin-bottom: 1.5rem;">The 5 Pillars</h2>
    <div style="display: grid; grid-template-columns: repeat(auto-fit, minmax(160px, 1fr)); gap: 1rem;">
      {[
        { icon: '🌿', name: 'Ecology', desc: 'Land, water, food, biodiversity, climate' },
        { icon: '🤝', name: 'Social', desc: 'Belonging, health, learning, culture' },
        { icon: '💰', name: 'Economy', desc: 'Resource circulation, shared models' },
        { icon: '🔧', name: 'Hardware', desc: 'Buildings, energy, water, infrastructure' },
        { icon: '⚖️', name: 'Governance', desc: 'Decisions, legal, membership, disputes' },
      ].map(p => (
        <div style="background: white; border-radius: 0.75rem; padding: 1.25rem; text-align: center; border-top: 4px solid #3d5a3e; box-shadow: 0 2px 8px rgba(0,0,0,0.07);">
          <div style="font-size: 2rem; margin-bottom: 0.5rem;">{p.icon}</div>
          <div style="font-weight: bold; color: #3d5a3e; margin-bottom: 0.375rem;">{p.name}</div>
          <div style="font-size: 0.8rem; color: #78716c; line-height: 1.4;">{p.desc}</div>
        </div>
      ))}
    </div>
  </section>

  <!-- 5 Phases timeline -->
  <section style="background: #e8dcc8; padding: 3rem 1.5rem;">
    <div style="max-width: 900px; margin: 0 auto;">
      <h2 style="font-size: 1.5rem; font-weight: bold; color: #3d5a3e; margin-bottom: 1.5rem;">The 5 Phases</h2>
      <div style="display: flex; flex-direction: column; gap: 0.75rem;">
        {[
          { num: 1, name: 'Proof of Concept', desc: 'Team formation, vision clarity, foundational governance', months: '0–6 months' },
          { num: 2, name: 'Feasibility Validation', desc: 'Economic modeling, location selection, capital strategy', months: '6–12 months' },
          { num: 3, name: 'Capital Formation', desc: 'Land acquisition, infrastructure funding', months: '12–24 months' },
          { num: 4, name: 'Construction & Activation', desc: 'Physical building, community culture', months: '24–36 months' },
          { num: 5, name: 'Continuous Regeneration', desc: 'Ongoing operations, adaptive management', months: '36+ months' },
        ].map(phase => (
          <div style="display: flex; align-items: flex-start; gap: 1rem; background: white; border-radius: 0.75rem; padding: 1rem 1.25rem; box-shadow: 0 1px 4px rgba(0,0,0,0.06);">
            <div style="background: #3d5a3e; color: white; width: 2rem; height: 2rem; border-radius: 50%; display: flex; align-items: center; justify-content: center; font-weight: bold; font-size: 0.9rem; flex-shrink: 0;">{phase.num}</div>
            <div style="flex: 1;">
              <div style="display: flex; justify-content: space-between; align-items: baseline; flex-wrap: wrap; gap: 0.25rem;">
                <span style="font-weight: bold; color: #3d5a3e;">{phase.name}</span>
                <span style="font-size: 0.8rem; color: #78716c;">{phase.months}</span>
              </div>
              <div style="font-size: 0.875rem; color: #44403c; margin-top: 0.25rem;">{phase.desc}</div>
            </div>
          </div>
        ))}
      </div>
    </div>
  </section>

  <!-- Full content -->
  <section style="max-width: 900px; margin: 3rem auto 4rem; padding: 0 1.5rem;">
    <h2 style="font-size: 1.5rem; font-weight: bold; color: #3d5a3e; margin-bottom: 1.5rem;">Full Framework Documentation</h2>
    <div style="background: white; border-radius: 1rem; padding: 2.5rem; box-shadow: 0 2px 12px rgba(0,0,0,0.07);">
      <div class="md-content" set:html={content} />
    </div>
  </section>

</Layout>

<style>
.md-content h1 { font-size: 1.75rem; font-weight: bold; color: #3d5a3e; margin-top: 2rem; margin-bottom: 1rem; }
.md-content h2 { font-size: 1.35rem; font-weight: bold; color: #3d5a3e; margin-top: 2rem; margin-bottom: 0.75rem; padding-bottom: 0.375rem; border-bottom: 2px solid #d4e8c8; }
.md-content h3 { font-size: 1.1rem; font-weight: 600; color: #5a7a4a; margin-top: 1.5rem; margin-bottom: 0.5rem; }
.md-content p { margin-bottom: 1rem; line-height: 1.75; }
.md-content ul, .md-content ol { padding-left: 1.5rem; margin-bottom: 1rem; }
.md-content li { margin-bottom: 0.375rem; line-height: 1.6; }
.md-content ul { list-style-type: disc; }
.md-content ol { list-style-type: decimal; }
.md-content blockquote { border-left: 4px solid #8fba7a; padding: 0.75rem 1.25rem; margin: 1.5rem 0; background: #f0f7ec; font-style: italic; color: #3d5a3e; border-radius: 0 0.375rem 0.375rem 0; }
.md-content table { width: 100%; border-collapse: collapse; margin-bottom: 1.5rem; font-size: 0.875rem; display: block; overflow-x: auto; }
.md-content th { background-color: #3d5a3e; color: #f5f0e8; padding: 0.625rem 1rem; text-align: left; }
.md-content td { border: 1px solid #e8dcc8; padding: 0.625rem 1rem; }
.md-content tr:nth-child(even) td { background-color: #faf8f4; }
.md-content strong { font-weight: bold; }
.md-content hr { border: none; border-top: 1px solid #e8dcc8; margin: 2rem 0; }
.md-content code { background: #e8dcc8; padding: 0.125rem 0.375rem; border-radius: 0.25rem; font-size: 0.85rem; font-family: monospace; }
</style>
