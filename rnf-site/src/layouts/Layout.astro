---
import '../styles/global.css';

interface Props {
  title: string;
  description?: string;
}

const { title, description = 'A visual guide to building regenerative neighborhoods.' } = Astro.props;

const base = import.meta.env.BASE_URL.replace(/\/$/, ''); // e.g. '' or '/rnf'

const nav = [
  { href: `${base}/`, label: 'Home' },
  { href: `${base}/journey`, label: 'The Journey' },
  { href: `${base}/frameworks/rnf`, label: 'RNF' },
  { href: `${base}/frameworks/alchemy`, label: 'Community Alchemy' },
  { href: `${base}/frameworks/rcos`, label: 'RCOS' },
  { href: `${base}/frameworks/clips`, label: 'CLIPS' },
];

const currentPath = Astro.url.pathname;
---

<html lang="en">
  <head>
    <meta charset="utf-8" />
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    <meta name="viewport" content="width=device-width" />
    <meta name="description" content={description} />
    <title>{title} | Regen Neighborhood Framework</title>
  </head>
  <body style="background-color: #f5f0e8; font-family: Georgia, serif; min-height: 100vh;">

    <!-- Nav -->
    <nav style="background-color: #3d5a3e; position: sticky; top: 0; z-index: 50; box-shadow: 0 2px 8px rgba(0,0,0,0.2);">
      <div style="max-width: 1200px; margin: 0 auto; padding: 0 1.5rem; display: flex; align-items: center; justify-content: space-between; height: 3.5rem;">
        <a href={`${base}/`} style="color: #f5f0e8; font-weight: bold; font-size: 1rem; text-decoration: none; letter-spacing: 0.02em;">
          🌿 Regen Neighborhood Framework
        </a>
        <div style="display: flex; gap: 0.25rem; flex-wrap: wrap;">
          {nav.map(({ href, label }) => (
            <a
              href={href}
              style={`color: ${currentPath === href ? '#b8d4a8' : '#d4e8c8'}; padding: 0.375rem 0.75rem; border-radius: 0.375rem; font-size: 0.875rem; text-decoration: none; background-color: ${currentPath === href ? 'rgba(255,255,255,0.15)' : 'transparent'}; transition: background 0.2s;`}
            >
              {label}
            </a>
          ))}
        </div>
      </div>
    </nav>

    <!-- Main -->
    <main style="min-height: calc(100vh - 3.5rem - 4rem);">
      <slot />
    </main>

    <!-- Footer -->
    <footer style="background-color: #3d5a3e; color: #b8d4a8; text-align: center; padding: 1.5rem; font-size: 0.875rem; margin-top: 4rem;">
      <p>Regen Neighborhood Framework — Open Source</p>
      <p style="margin-top: 0.25rem; opacity: 0.7;">
        <a href="https://github.com/regentribes/regen-neighborhood-framework" style="color: #b8d4a8;" target="_blank">View source on GitHub</a>
      </p>
    </footer>

  </body>
</html>
