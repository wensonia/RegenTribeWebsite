---
interface Props {
  content: string;
}
const { content } = Astro.props;
---

<div class="md-content" set:html={content} />

<style>
.md-content h1 { font-size: 2rem; font-weight: bold; color: #3d5a3e; margin-top: 2rem; margin-bottom: 1rem; }
.md-content h2 { font-size: 1.5rem; font-weight: bold; color: #3d5a3e; margin-top: 2.5rem; margin-bottom: 0.75rem; padding-bottom: 0.5rem; border-bottom: 2px solid #d4e8c8; }
.md-content h3 { font-size: 1.2rem; font-weight: 600; color: #5a7a4a; margin-top: 1.75rem; margin-bottom: 0.5rem; }
.md-content h4 { font-size: 1rem; font-weight: 600; color: #8b6b4a; margin-top: 1.25rem; margin-bottom: 0.375rem; }
.md-content p { margin-bottom: 1rem; line-height: 1.75; color: #1c1917; }
.md-content ul { list-style-type: disc; padding-left: 1.5rem; margin-bottom: 1rem; }
.md-content ol { list-style-type: decimal; padding-left: 1.5rem; margin-bottom: 1rem; }
.md-content li { margin-bottom: 0.375rem; line-height: 1.6; color: #1c1917; }
.md-content blockquote { border-left: 4px solid #8fba7a; padding: 0.75rem 1.25rem; margin: 1.5rem 0; background: #f0f7ec; border-radius: 0 0.375rem 0.375rem 0; font-style: italic; color: #3d5a3e; }
.md-content table { width: 100%; border-collapse: collapse; margin-bottom: 1.5rem; font-size: 0.9rem; overflow-x: auto; display: block; }
.md-content th { background-color: #3d5a3e; color: #f5f0e8; padding: 0.625rem 1rem; text-align: left; font-size: 0.875rem; }
.md-content td { border: 1px solid #e8dcc8; padding: 0.625rem 1rem; }
.md-content tr:nth-child(even) td { background-color: #faf8f4; }
.md-content code { background: #e8dcc8; padding: 0.125rem 0.375rem; border-radius: 0.25rem; font-size: 0.875rem; font-family: monospace; }
.md-content pre { background: #1c1917; color: #f5f0e8; padding: 1.25rem; border-radius: 0.5rem; overflow-x: auto; margin-bottom: 1rem; }
.md-content pre code { background: none; padding: 0; }
.md-content strong { font-weight: bold; color: #1c1917; }
.md-content a { color: #6b9ab8; text-decoration: underline; }
.md-content hr { border: none; border-top: 1px solid #e8dcc8; margin: 2rem 0; }
</style>
